{
	"name": "cafeto-gutenberg-blocks",
	"version": "0.1.0",
	"description": "Cafeto plugin to install custom Gutenberg blocks",
	"author": "Cafeto Team",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build:webpack": "wp-scripts build --webpack-copy-php",
		"build:tailwind": "tailwindcss -i ./src/styles.css -o ./build/styles.css --minify",
		"build": "concurrently \"npm run build:webpack\" \"npm run build:tailwind\"",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start:webpack": "wp-scripts start --webpack-copy-php",
		"start:tailwind": "tailwindcss -i ./src/styles.css -o ./build/styles.css --watch",
		"start": "concurrently \"npm run start:webpack\" \"npm run start:tailwind\""
	},
	"devDependencies": {
		"@wordpress/scripts": "^27.9.0",
		"copy-webpack-plugin": "^12.0.2"
	},
	"dependencies": {
		"@heroicons/react": "^2.1.5",
		"concurrently": "^9.0.1",
		"postcss": "^8.4.47",
		"react-beautiful-dnd": "^13.1.1",
		"react-select": "^5.8.0",
		"tailwindcss": "^3.4.13"
	}
}
